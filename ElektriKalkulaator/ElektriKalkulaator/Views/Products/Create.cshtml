@* Add new product *@
@model ElektriKalkulaator.Core.Dto.ProductDto

@{
    ViewData["Title"] = "Lisa uus toode";
}

<div class="mb-3">
    <a asp-action="Index" class="btn btn-secondary btn-sm">← Tagasi</a>
</div>

<div class="row justify-content-center">
    <div class="col-lg-7">
        <div class="card p-4">
            <h4 class="text-white fw-bold mb-4">➕ Lisa uus toode</h4>

            <form asp-action="Create" method="post">
                @Html.AntiForgeryToken()

                <div class="row g-3">
                    <div class="col-md-6">
                        <label asp-for="Name" class="form-label">Toote nimi *</label>
                        <input asp-for="Name" class="form-control" placeholder="nt ABB S201-B16" />
                        <span asp-validation-for="Name" class="text-danger small"></span>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="Brand" class="form-label">Tootja *</label>
                        <input asp-for="Brand" class="form-control" placeholder="nt ABB" />
                        <span asp-validation-for="Brand" class="text-danger small"></span>
                    </div>
                    <div class="col-md-12">
                        <label asp-for="CategoryId" class="form-label">Kategooria *</label>
                        @* ViewBag.Categories is a SelectList — Razor renders it as <option> elements *@
                        <select asp-for="CategoryId" asp-items="ViewBag.Categories" class="form-select">
                            <option value="">-- Vali kategooria --</option>
                        </select>
                        <span asp-validation-for="CategoryId" class="text-danger small"></span>
                    </div>
                    <div class="col-md-4">
                        <label asp-for="RatedCurrent" class="form-label">Nimivool (A)</label>
                        <input asp-for="RatedCurrent" type="number" step="0.01" class="form-control" />
                    </div>
                    <div class="col-md-4">
                        <label asp-for="Voltage" class="form-label">Nimipinge (V)</label>
                        <input asp-for="Voltage" type="number" step="0.01" class="form-control" />
                    </div>
                    <div class="col-md-4">
                        <label asp-for="WireCrossSectionMm2" class="form-label">Juhtme ristlõige (mm²)</label>
                        <input asp-for="WireCrossSectionMm2" type="number" step="0.01" class="form-control" />
                    </div>
                    <div class="col-md-6">
                        <label asp-for="Price" class="form-label">Hind (€) *</label>
                        <input asp-for="Price" type="number" step="0.01" class="form-control" />
                        <span asp-validation-for="Price" class="text-danger small"></span>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="StockQuantity" class="form-label">Laoseis (tk)</label>
                        <input asp-for="StockQuantity" type="number" class="form-control" />
                    </div>
                    <div class="col-12">
                        <label asp-for="Description" class="form-label">Kirjeldus</label>
                        <textarea asp-for="Description" class="form-control" rows="3"></textarea>
                    </div>
                </div>

                <div class="d-flex gap-2 mt-4">
                    <button type="submit" class="btn btn-amber">💾 Salvesta</button>
                    <a asp-action="Index" class="btn btn-secondary">Tühista</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
