@* Toodete kataloog — filtri ja otsinguiga *@
@model IEnumerable<ElektriKalkulaator.Core.Domain.Product>

@{
    ViewData["Title"] = "Tooted";
}

<div class="d-flex justify-content-between align-items-end mb-4">
    <div>
        <h1 class="page-title">📦 Toodete kataloog</h1>
        <p class="page-subtitle">ABB, Schneider, Hager elektrikomponendid</p>
    </div>
    <a asp-action="Create" class="btn btn-amber">+ Lisa toode</a>
</div>

<!-- FILTRID -->
<div class="card p-3 mb-4">
    <form method="get" asp-action="Index" class="row g-3 align-items-end">
        <div class="col-md-5">
            <label class="form-label">Kategooria</label>
            @* asp-items = Razor lülitab SelectList automaatselt <option> elementideks *@
            <select name="categoryId" class="form-select"
                    asp-items="@(ViewBag.Categories as Microsoft.AspNetCore.Mvc.Rendering.SelectList)">
                <option value="">Kõik kategooriad</option>
            </select>
        </div>
        <div class="col-md-5">
            <label class="form-label">Otsi nime järgi</label>
            <input type="text" name="searchTerm" value="@ViewBag.SearchTerm"
                   class="form-control" placeholder="nt ABB, NYM, kaitselüliti..." />
        </div>
        <div class="col-md-2">
            <button type="submit" class="btn btn-primary w-100">🔍 Otsi</button>
        </div>
    </form>
</div>

<!-- TOOTEKAARDID -->
@if (!Model.Any())
{
    <div class="card p-5 text-center">
        <div style="font-size: 3rem; opacity: 0.3; margin-bottom: 1rem;">📦</div>
        <h5 class="text-white">Tooteid ei leitud</h5>
        <p class="text-muted-custom small">Muuda filtrit või lisa uusi tooteid.</p>
    </div>
}
else
{
    <div class="row g-3">
        @foreach (var product in Model)
        {
            <div class="col-sm-6 col-lg-4 col-xl-3">
                <div class="product-card">
                    <!-- Toote nimi ja tootja -->
                    <div class="mb-2">
                        <div class="fw-semibold text-white small">@product.Name</div>
                        <div class="text-muted-custom" style="font-size: 0.75rem;">@product.Brand</div>
                    </div>

                    <!-- Kategooria -->
                    @if (product.Category != null)
                    {
                        <div class="mb-2">
                            <span class="badge bg-secondary" style="font-size: 0.65rem;">
                                @product.Category.Name
                            </span>
                        </div>
                    }

                    <!-- Tehnilised märgised -->
                    <div class="d-flex flex-wrap gap-1 mb-3">
                        @if (product.RatedCurrent > 0)
                        {
                            <span class="product-badge badge-ampere">@product.RatedCurrent A</span>
                        }
                        @if (product.WireCrossSectionMm2.HasValue)
                        {
                            <span class="product-badge badge-wire">@product.WireCrossSectionMm2 mm²</span>
                        }
                    </div>

                    <!-- Laoseis -->
                    <div class="mb-2">
                        @if (product.StockQuantity > 10)
                        {
                            <span class="badge-stock-ok">✅ Laos: @product.StockQuantity tk</span>
                        }
                        else if (product.StockQuantity > 0)
                        {
                            <span class="badge-stock-low">⚠️ Vähe: @product.StockQuantity tk</span>
                        }
                        else
                        {
                            <span class="badge-stock-none">❌ Otsas</span>
                        }
                    </div>

                    <!-- Hind ja tegevused -->
                    <div class="mt-auto">
                        <div class="price-tag-small mb-2">@product.Price.ToString("F2") €</div>
                        <div class="d-flex gap-2">
                            <a asp-action="Details" asp-route-id="@product.Id"
                               class="btn btn-sm btn-secondary flex-fill" style="font-size:0.75rem">
                                Detailid
                            </a>
                            @if (product.StockQuantity > 0)
                            {
                                <form asp-controller="Cart" asp-action="Add" method="post" class="flex-fill">
                                    <input type="hidden" name="productId" value="@product.Id" />
                                    <input type="hidden" name="quantity" value="1" />
                                    <input type="hidden" name="returnUrl" value="/Products" />
                                    <button type="submit" class="btn btn-sm btn-amber w-100" style="font-size:0.75rem">
                                        🛒 Lisa
                                    </button>
                                </form>
                            }
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>

    <div class="mt-3 text-muted-custom small">
        Näidatakse @Model.Count() toodet
    </div>
}

<!-- ADMIN LINGID -->
<hr class="section-divider mt-4" />
<div class="d-flex gap-2">
    <a asp-action="Categories" class="btn btn-secondary btn-sm">⚙️ Halda kategooriaid</a>
</div>
